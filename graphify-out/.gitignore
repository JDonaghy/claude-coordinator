# Track only the durable, queryable graph artifacts:
#   graph.json, GRAPH_REPORT.md, manifest.json, .graphify_labels.json
# Everything below is regenerable by the post-commit/post-checkout hooks,
# machine-specific, or a stray snapshot — so it stays out of git.
# (gitignore has no inline comments; keep each rule on its own line.)

# content-hashed extraction cache — regenerable, grows unbounded
cache/

# absolute machine-specific paths (scan root / interpreter)
.graphify_root
.graphify_python

# regenerable viz; not emitted above 5000 nodes (graphify export html)
graph.html

# local token-cost tracker
cost.json

# stray dated output snapshots (e.g. 2026-06-07/)
20*/
